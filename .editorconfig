# Top-most EditorConfig file
root = true

# Global Settings - Indent and Charset only
[*]
indent_style = space
indent_size = 4
tab_width = 4
charset = utf-8

# RELAXED RULES: No enforcement on line endings or whitespaces
end_of_line = unset
trim_trailing_whitespace = unset
insert_final_newline = unset

[*.cs]
#### 1. Language Rules (Modern C#) ####
dotnet_style_qualification_for_field = false:silent
dotnet_style_qualification_for_property = false:silent
dotnet_style_qualification_for_method = false:silent
dotnet_style_qualification_for_event = false:silent

dotnet_style_predefined_type_for_locals_parameters_extract_method = true:suggestion
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

#### 2. Naming Conventions (Strict - Keep these!) ####
dotnet_naming_rule.interface_should_be_begins_with_i.severity = error
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface_symbols
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i_style
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.begins_with_i_style.required_prefix = I
dotnet_naming_style.begins_with_i_style.capitalization = pascal_case

dotnet_naming_rule.private_fields_should_be_underscore.severity = error
dotnet_naming_rule.private_fields_should_be_underscore.symbols = private_field_symbols
dotnet_naming_rule.private_fields_should_be_underscore.style = underscore_style
dotnet_naming_symbols.private_field_symbols.applicable_kinds = field
dotnet_naming_symbols.private_field_symbols.applicable_accessibilities = private
dotnet_naming_style.underscore_style.required_prefix = _
dotnet_naming_style.underscore_style.capitalization = camel_case

#### 3. Relaxed Formatting & Imports ####
# This stops 'dotnet format' from caring about using statement order
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = false
dotnet_style_required_symbols_for_it_to_be_considered_organized = none

#### 4. Analyzer & Formatting Silencing (The "Shut Up" Section) ####
# Disable Whitespace/Formatting diagnostics
dotnet_diagnostic.WHITESPACE.severity = none
dotnet_diagnostic.FINALNEWLINE.severity = none
dotnet_diagnostic.IDE0055.severity = none

# Disable Import/Using organization diagnostics
dotnet_diagnostic.IMPORTS.severity = none
dotnet_diagnostic.IDE0005.severity = none
dotnet_diagnostic.IDE0065.severity = none

# General Analyzers
dotnet_diagnostic.CA1822.severity = warning
dotnet_diagnostic.CA1823.severity = error
