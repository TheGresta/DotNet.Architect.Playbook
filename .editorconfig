# Top-most EditorConfig file
root = true

# All files - Standard Whitespace & Encoding
[*]
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# Files - The "Clean Code" Rules
[*.cs]

#### 1. Language Rules (Modern C#) ####

# Force "var" when the type is obvious (newing up, casting), but use explicit types elsewhere
# Professional tip: This keeps code clean but readable for juniors.
dotnet_style_qualification_for_field = false:silent
dotnet_style_qualification_for_property = false:silent
dotnet_style_qualification_for_method = false:silent
dotnet_style_qualification_for_event = false:silent

# Prefer "var" over explicit type
dotnet_style_predefined_type_for_locals_parameters_extract_method = true:error
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:error
csharp_style_var_elsewhere = false:suggestion

# Use "Expression Bodied Members" for simple logic (one-liners)
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_operators = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion

# Null-checking preferences
csharp_style_throw_expression = true:error
csharp_style_conditional_delegate_call = true:error

#### 2. Naming Conventions (Enterprise Standards) ####

# Interfaces must start with 'I'
dotnet_naming_rule.interface_should_be_begins_with_i.severity = error
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface_symbols
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i_style

dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.begins_with_i_style.required_prefix = I
dotnet_naming_style.begins_with_i_style.capitalization = pascal_case

# Private fields must start with '_'
dotnet_naming_rule.private_fields_should_be_underscore.severity = error
dotnet_naming_rule.private_fields_should_be_underscore.symbols = private_field_symbols
dotnet_naming_rule.private_fields_should_be_underscore.style = underscore_style

dotnet_naming_symbols.private_field_symbols.applicable_kinds = field
dotnet_naming_symbols.private_field_symbols.applicable_accessibilities = private
dotnet_naming_style.underscore_style.required_prefix = _
dotnet_naming_style.underscore_style.capitalization = camel_case

#### 3. Formatting Rules (Clean & Consistent) ####

# New line preferences (Allman Style - Industry Standard)
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_between_query_expression_clauses = true

# Braces (Always use them, even for one-liners)
csharp_prefer_braces = true:error

#### 4. Organizing Usings ####

# Keep system usings at the top and sort them
dotnet_separate_import_directive_groups = true
dotnet_sort_system_directives_first = true

#### 5. Analyzer Severity (Performance & Quality) ####

# Unused private members = Error
dotnet_diagnostic.CA1822.severity = warning
dotnet_diagnostic.CA1823.severity = error
